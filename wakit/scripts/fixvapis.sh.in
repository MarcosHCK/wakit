base_dir="@base_dir@"
python_exe="@python_exe@"
fixvapis_exe="@fixvapis_exe@"
fixvapis_py="@fixvapis_py@"

$python_exe "$fixvapis_py" -b "$base_dir" --bin "$fixvapis_exe" "$base_dir/example"
$python_exe "$fixvapis_py" -b "$base_dir" --bin "$fixvapis_exe" "$base_dir/tests"
$python_exe "$fixvapis_py" -b "$base_dir" --bin "$fixvapis_exe" "$base_dir/wakit"