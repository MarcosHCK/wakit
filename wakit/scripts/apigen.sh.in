apigen_py="@apigen_py@"
apigen_exe="@apigen_exe@"
introspect_exe="@introspect_exe@"
python_exe="@python_exe@"

$python_exe "$apigen_py" --apigen-bin "$apigen_exe" --introspect-bin "$introspect_exe" "$@"