{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "paths": {
      "@wakit-companion/*": ["./src/companion/"]
    }
  },
  "include": [ "src/**/*.ts" ],
  "typeRoots": [ "src/companion/types/" ],
}