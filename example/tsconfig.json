{
  "compilerOptions": {
    "target": "es2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsxdev",
    "incremental": true,
    "paths": {
      "@wakit-example/*": ["./*"]
    }
  },
  "include": [ "./hooks/**/*.js", "./hooks/**/*.jsx", "./hooks/**/*.ts", "./hooks/**/*.tsx",
               "./parts/**/*.js", "./parts/**/*.jsx", "./parts/**/*.ts", "./parts/**/*.tsx",
               "./routes/**/*.js", "./routes/**/*.jsx", "./routes/**/*.ts", "./routes/**/*.tsx",
               "./types/**/*.d.ts",
               "./*.ts", "./*.tsx", "./*.js", "./*.jsx" ],
  "exclude": [ "./node_modules/" ]
}
