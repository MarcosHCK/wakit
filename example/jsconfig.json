{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsxdev",
    "incremental": true,
    "paths": {
      "@wakit-example/*": ["./*"]
    }
  },
  "include": [ "**/*.js", "**/*.jsx" ],
  "exclude": [ "./node_modules/**/*", "./routes.gen.ts" ]
}