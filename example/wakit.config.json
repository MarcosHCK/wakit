{
  "application-id": "org.hck.wakit.Simple.Application",
  "application-version": "v0.0.0-devel",
  "default-route": "app:///",
  "extensions-dir": "src/extension/",
  "modules": {
    "base-dir": "example/",
    "items": [
      {
        "name": "wakit-example",
        "loader": "c",
        "type-prefix": "org.hck.wakit.Example"
      }
    ]
  },
  "schemes": [
    {
      "aliases": [
        {
          "path": "/",
          "replacement": "/app.html"
        },
        {
          "verbatim": true
        }
      ],
      "local": true,
      "name": "app",
      "tree": "../example/dist/"
    }
  ],
  "secure_schemes": [
    "app"
  ]
}