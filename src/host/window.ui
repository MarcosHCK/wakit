<interface domain="en_US">

  <template class="WakitHostApplicationWindow" parent="GtkApplicationWindow">

    <child>

      <object class="GtkGrid" id="_grid">

        <property name="hexpand">True</property>
        <property name="vexpand">True</property>
      </object>
    </child>
  </template>
</interface>