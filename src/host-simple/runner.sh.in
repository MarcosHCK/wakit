binary="@host_simple_bin_path@"

extra_paths=("@common_lib_path@"
             "@extension_lib_path@"
             "@extension_mod_path@"
             "@host_lib_path@"
             "@host_simple_lib_path@"
             $LD_LIBRARY_PATH)

IFS=":"
extra_paths="${extra_paths[*]}"

LD_LIBRARY_PATH="$extra_paths" $binary $@